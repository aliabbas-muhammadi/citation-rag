# Copy to .env.local (gitignored) and fill in. NEVER commit real secrets.

# Corpus backend: "mock" (bundled sample, no DB) or "supabase" (your real corpus).
CORPUS_BACKEND="mock"

# Anthropic API key — enables live, model-generated cited answers.
# Without it, the app/eval run in deterministic offline mode.
# ANTHROPIC_API_KEY="sk-ant-..."

# Optional model overrides.
# GENERATION_MODEL="claude-opus-4-8"   # answer generation (default)
# JUDGE_MODEL="claude-opus-4-8"        # eval faithfulness judge

# --- Only needed when CORPUS_BACKEND=supabase ---
# SUPABASE_URL=""
# SUPABASE_SERVICE_ROLE_KEY=""
# Embeddings provider for dense retrieval (e.g. OpenAI):
# OPENAI_API_KEY=""
