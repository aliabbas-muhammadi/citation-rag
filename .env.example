# Copy to .env.local (gitignored) and fill in. NEVER commit real secrets.

# Corpus backend: "mock" (bundled founding-documents corpus, no DB) or
# "supabase" (the production Postgres/pgvector path — see lib/rag/corpus.ts).
CORPUS_BACKEND="mock"

# OpenAI key — enables DENSE retrieval (live query embedding via
# text-embedding-3-small). Without it, retrieval degrades to BM25-only.
# OPENAI_API_KEY="sk-..."

# Anthropic key — enables live, streamed, model-generated cited answers.
# Without it, the app/eval run in deterministic offline mode.
# ANTHROPIC_API_KEY="sk-ant-..."

# Public site URL (used for metadata / Open Graph).
# NEXT_PUBLIC_SITE_URL="https://ask.alimuhammadi.com"

# Optional model overrides.
# GENERATION_MODEL="claude-opus-4-8"   # answer generation (default)
# JUDGE_MODEL="claude-opus-4-8"        # eval faithfulness judge / rerank / rewrite

# --- Only needed when CORPUS_BACKEND=supabase (production corpus) ---
# SUPABASE_URL=""
# SUPABASE_SERVICE_ROLE_KEY=""
